find /build/shim-16.1 -type f -a '(' -iname '*.c' -o -iname '*.h' -o -iname '*.S' ')' | while read file ; do \
	outfile=$(echo ${file} | sed -e "s,^/build/shim-16.1,,") ; \
	install -d -m 0755 /build/shim-16.1/debian/tmp//usr/src/debug//shim-16.1-16.1/$(dirname ${outfile}) ; \
	install -m 0644 ${file} /build/shim-16.1/debian/tmp//usr/src/debug//shim-16.1-16.1/${outfile} ; \
done
